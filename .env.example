# ER Investigation Platform — Environment Configuration

# Anthropic API Key
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=your-api-key-here

# AI Model
ANTHROPIC_MODEL=claude-sonnet-4-6

# Application Settings
PORT=3000
CASE_FILES_PATH=./cases
NODE_ENV=development

# Database (SQLite — path to the .db file)
# Defaults to ./data/er_platform.db if not set
DATABASE_PATH=./data/er_platform.db

# NameMap Encryption Key (REQUIRED)
# 64 hex characters = 32 bytes = 256-bit AES-GCM key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET. Losing this key means NameMaps cannot be decrypted.
NAMEMAP_ENCRYPTION_KEY=your-64-char-hex-key-here
